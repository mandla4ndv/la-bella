rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Settings — public read, admin write
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services — public read, admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery — public read, admin write
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials — public read of active, admin write
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users — users can read/write their own, admin can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Appointments — users can create and read their own, admin can read/write all
    match /appointments/{appointmentId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if true; // Allow guest bookings too
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Contact messages — anyone can create, admin reads
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Notifications — admin only
    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
    }
  }
}
